HOST=0.0.0.0
PORT=3100
PUBLIC_BASE_URL=http://192.168.31.246:3100
# Admin UI/API protection. Keep ADMIN_TOKEN in a private secrets file in production.
ADMIN_TOKEN=replace-with-random-admin-token
ADMIN_PUBLIC_HOSTS=wave.xionglei.online
ADMIN_PROTECT_PUBLIC_MUTATIONS=1
# Optional Cloudflare Access protection for /admin and /api/admin.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=
CLOUDFLARE_ACCESS_REQUIRED=0
# Required before exposing /api/ai/xiaozhi/tool to the public internet.
# XIAOZHI_TOOL_TOKEN=replace-with-random-token
DATA_DIR=./data
RESOURCE_DIR=./data/resources
# OPENCLAW_COMMAND=/usr/local/bin/openclaw
# MUSIC_SERVER_URL=http://127.0.0.1:8096
# NAS_MUSIC_DIR=/mnt/nas/music
# Comma separated providers: rss,archive,direct,catalog. Local server files are always searched first.
ONLINE_MEDIA_PROVIDERS=rss,archive,direct
# Example: ONLINE_MEDIA_FEEDS=https://example.com/podcast.xml,https://example.com/kids.xml
ONLINE_MEDIA_FEEDS=
ONLINE_MEDIA_ALLOW_DIRECT_URLS=1
# Keep this off for public gateways unless you intentionally allow LAN/NAS HTTP sources.
ONLINE_MEDIA_ALLOW_PRIVATE_HOSTS=0
ONLINE_MEDIA_TIMEOUT_MS=4500
ONLINE_MEDIA_MAX_RESULTS=6
# Voice weather queries use the scheduled cache. Explicit refresh waits at most 800 ms.
WEATHER_AGENT_CACHE_MAX_AGE_MS=2100000
WEATHER_AGENT_REFRESH_TIMEOUT_MS=800
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=replace-with-long-lived-access-token
